{
  "multipart": [
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection"
      },
      "when": {
        "down": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection_blocked"
      },
      "when": {
        "down": "blocked"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection",
        "x": 180
      },
      "when": {
        "up": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection_blocked",
        "x": 180
      },
      "when": {
        "up": "blocked"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection",
        "x": 90,
        "y": 180
      },
      "when": {
        "north": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection_blocked",
        "x": 90,
        "y": 180
      },
      "when": {
        "north": "blocked"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection",
        "x": 90,
        "y": 270
      },
      "when": {
        "east": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection_blocked",
        "x": 90,
        "y": 270
      },
      "when": {
        "east": "blocked"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection",
        "x": 90
      },
      "when": {
        "south": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection_blocked",
        "x": 90
      },
      "when": {
        "south": "blocked"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection",
        "x": 90,
        "y": 90
      },
      "when": {
        "west": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_connection_blocked",
        "x": 90,
        "y": 90
      },
      "when": {
        "west": "blocked"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/iron_fluid_pipe_base_blocked"
      }
    }
  ]
}