{
  "multipart": [
    {
      "apply": {
        "model": "buildcraft:block/diamond_fluid_pipe_connection_down"
      },
      "when": {
        "down": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/diamond_fluid_pipe_connection_up",
        "x": 180
      },
      "when": {
        "up": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/diamond_fluid_pipe_connection_north",
        "x": 90,
        "y": 180
      },
      "when": {
        "north": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/diamond_fluid_pipe_connection_east",
        "x": 90,
        "y": 270
      },
      "when": {
        "east": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/diamond_fluid_pipe_connection_south",
        "x": 90
      },
      "when": {
        "south": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/diamond_fluid_pipe_connection_west",
        "x": 90,
        "y": 90
      },
      "when": {
        "west": "connected"
      }
    },
    {
      "apply": {
        "model": "buildcraft:block/diamond_fluid_pipe_base"
      }
    }
  ]
}